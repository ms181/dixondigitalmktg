---
const services = [
  {
    name: 'Strategic Marketing & Brand Growth',
    description:
      'We build clarity before we chase growth. From positioning and messaging to audience alignment, every move is designed to compound, not just perform.',
    action: 'Build My Strategy',
    isFlagged: true,
    features: [
      'Brand positioning and messaging clarity',
      'Target audience refinement',
      'Growth-focused marketing strategy',
      'Channel and funnel planning',
      'Ongoing optimization and direction',
    ],
  },
  {
    name: 'Content Creation & Social Media',
    description:
      'Content that does more than exist. We create, manage, and refine everything so your brand shows up sharp, consistent, and worth paying attention to.',
    isFlagged: true,
    action: 'Scale My Content',
    features: [
      'Content calendars and planning',
      'Copywriting and creative direction',
      'Design and brand consistency',
      'Posting and platform management',
      'Engagement and performance tracking',
    ],
  },
  {
    name: 'Partnerships, Outreach & Networking',
    description:
      'We put your brand in the right rooms. Strategic collaborations and relationships that expand reach, credibility, and real opportunities.',
    action: 'Expand My Reach',
    isFlagged: true,
    features: [
      'Brand and influencer partnerships',
      'Outreach strategy and execution',
      'Collaboration sourcing',
      'Network building and positioning',
      'Long-term relationship development',
    ],
  },
  {
    name: 'Consulting',
    description:
      'No guesswork, just direction. We audit what you are doing, fix what is not working, and give you a clear path forward.',
    action: 'Get Clarity',
    isFlagged: true,
    features: [
      'Marketing and brand audit',
      'Strategy and goal alignment',
      'Gap and opportunity analysis',
      'Platform-specific recommendations',
      'One-time or ongoing advisory',
    ],
  },
];
---

<section class="py-16 sm:py-20">
  <div class="mx-auto max-w-2xl px-4 sm:px-6 lg:max-w-7xl lg:px-8">
    <div class="-mt-8 grid gap-8 lg:mt-0 lg:grid-cols-2">
      {
        services.map((item) => (
          <div
            class:list={[
              'relative flex flex-col gap-8 rounded-3xl p-8',
              item.isFlagged && 'bg-primary-500/10 dark:bg-primary-400/10',
            ]}
          >
            <div class="flex-1">
              <h2 class="text-xl font-medium">{item.name}</h2>

              <p class="mt-6 text-primary-950/70 dark:text-primary-200/70">{item.description}</p>

              <ul role="list" class="mt-6 space-y-6">
                {item.features.map((feature) => (
                  <li class="flex gap-3">
                    <svg
                      class="h-6 w-6 flex-shrink-0 text-primary-600 dark:text-primary-400"
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 24 24"
                      fill="currentColor"
                      aria-hidden="true"
                    >
                      <path d="M12 22C6.47715 22 2 17.5228 2 12C2 6.47715 6.47715 2 12 2C17.5228 2 22 6.47715 22 12C22 17.5228 17.5228 22 12 22ZM11.0026 16L18.0737 8.92893L16.6595 7.51472L11.0026 13.1716L8.17421 10.3431L6.75999 11.7574L11.0026 16Z" />
                    </svg>
                    <span>{feature}</span>
                  </li>
                ))}
              </ul>
            </div>

            <a
              href="/contact"
              class="inline-flex w-full items-center justify-center rounded-full border border-transparent bg-primary-600 px-5 py-3 text-base font-medium text-white transition hover:bg-primary-700 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-600 dark:bg-primary-400 dark:text-primary-950 dark:hover:bg-primary-300 dark:focus-visible:outline-primary-400"
            >
              {item.action}
            </a>
          </div>
        ))
      }
    </div>
  </div>
</section>
